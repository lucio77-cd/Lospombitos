// ============================================================
//  firestore.rules — RASCUNHO
//
//  ⚠️ IMPORTANTE: eu não tinha o arquivo de rules atual do projeto,
//  então isto foi reconstruído do zero a partir do que o código
//  client faz. Antes de publicar em produção:
//    1. Teste no Firebase Console → Firestore → Regras → Playground
//       simulando as operações reais de cada página (login, postar,
//       comprar/vender, ver feed, ver "Descobrir Membros" etc.)
//    2. Ou rode com o Firebase Emulator Suite localmente.
//  Algumas coleções (galeria, leiloes/lances, pagamentos, transacoes)
//  eu não auditei a fundo — marquei com "REVISAR" abaixo. Rules erradas
//  quebram o app (não deixam nem o dono ler/escrever), então valide
//  com calma, coleção por coleção.
//
//  PREMISSA CENTRAL desta versão:
//  - saldo_disponivel, patrimonio_total, rentabilidade_pct (em
//    "usuarios") e TUDO em "carteiras" e "ordens" só podem ser
//    escritos pelo servidor (Firebase Admin SDK em api/executar-ordem.js),
//    que ignora estas regras. Por isso as regras abaixo NEGAM escrita
//    direta do client nesses campos/coleções.
//  - pombcoins (em "usuarios") AINDA é escrito direto pelo client em
//    pomb-economy.js — as regras abaixo permitem isso por enquanto
//    (senão o $POMB quebra), mas isso significa que o $POMB continua
//    vulnerável a alguém rodar POMB._creditar() manualmente no
//    console. Se o $POMB importa pra valer (ele decide lances de
//    leilão), esse é o próximo passo a mover pro servidor.
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function logado() {
      return request.auth != null;
    }

    function ehDono(uid) {
      return logado() && request.auth.uid == uid;
    }

    // ── usuarios/{uid} ──
    // Leitura: qualquer membro autenticado (necessário para o feed
    // e para "Descobrir Membros" mostrarem outros perfis/saldos).
    // Escrita: só o dono, e só em campos de perfil — nunca em saldo,
    // patrimônio ou rentabilidade (isso é papel do servidor).
    match /usuarios/{uid} {
      allow read: if logado();

      allow create: if ehDono(uid);

      allow update: if ehDono(uid) &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['saldo_disponivel', 'patrimonio_total', 'rentabilidade_pct']);

      // Subcoleção de histórico do $POMB — só o dono lê/escreve
      match /pomb_historico/{docId} {
        allow read, create: if ehDono(uid);
        allow update, delete: if false;
      }
    }

    // ── carteiras/{uid} ──
    // Atualizações de saldo (comprar/vender) só o servidor (Admin SDK,
    // api/executar-ordem.js) escreve. MAS a criação inicial da carteira
    // (germinarEsalvarPombito, em auth.js) ainda roda no client — por
    // isso liberamos SÓ a criação, travada nos valores exatos de capital
    // inicial, pra não travar o cadastro. Update/delete continuam só do
    // servidor.
    match /carteiras/{uid} {
      allow read: if ehDono(uid);

      allow create: if ehDono(uid) &&
        request.resource.data.uid == uid &&
        request.resource.data.saldo_disponivel == 500000 &&
        request.resource.data.saldo_investido == 0 &&
        request.resource.data.patrimonio_total == 500000 &&
        request.resource.data.posicoes == [] &&
        request.resource.data.historico_ordens == [];

      allow update, delete: if false;
    }

    // ── posicoes_daytrade/{id} (PIT 24H) ──
    // Faltava por completo nesta versão — o game-estudo.html não
    // conseguia nem LER as próprias posições. Escrita continua só do
    // servidor (api/daytrade-fechar.js, mesmo padrão de ordens).
    match /posicoes_daytrade/{id} {
      allow read: if logado() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ── ordens/{id} ──
    // Só o servidor cria (via api/executar-ordem.js). O client só lê as
    // próprias ordens.
    match /ordens/{id} {
      allow read: if logado() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    // ── convites/{codigo} ──
    // Leitura pública (o fluxo de convite lê o código ANTES do login,
    // ver auth.js). Como o ID do documento é um código aleatório de
    // 6 caracteres, isso não permite listar convites de outra pessoa,
    // só confirmar um código que você já tem em mãos.
    // Criação: só o dono autenticado, gerando pra si mesmo, não usado.
    // Uso (marcar como usado): só se ainda não tiver sido usado.
    match /convites/{codigo} {
      allow get: if true;
      allow list: if false;

      allow create: if logado() &&
        request.resource.data.gerado_por == request.auth.uid &&
        request.resource.data.usado == false;

      allow update: if logado() &&
        resource.data.usado == false &&
        request.resource.data.usado == true &&
        request.resource.data.quem_usou == request.auth.uid;

      allow delete: if false;
    }

    // ── posts/{id} ──
    // Client pode criar posts próprios, MAS nunca do tipo "trade"
    // (esses só vêm do servidor, junto da execução da ordem — evita
    // alguém postar uma "compra" falsa pro feed sem ela ter acontecido).
    match /posts/{id} {
      allow read: if logado();

      allow create: if logado() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.tipo != 'trade';

      // Curtidas: permite só incrementar 'likes' em 1, mais nada.
      // (REVISAR: confirme contra a implementação real de darLike()
      // em feed.html antes de publicar — hoje eu não tracei esse fluxo.)
      allow update: if logado() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']);

      allow delete: if logado() && resource.data.uid == request.auth.uid;
    }

    // ── REVISAR: coleções que eu não auditei em profundidade ──
    // Deixei fechadas por padrão (allow: if false) até você confirmar
    // o fluxo real de cada uma — abrir demais aqui é o tipo de coisa
    // que vaza dado ou permite escrita indevida sem ninguém perceber.
    // Auditado contra galeria.html e arte-semanal.js: o dono só mexe em
    // a_venda/preco/colocada_venda_em da própria obra; a compra (feita
    // pelo comprador) troca dono_uid/a_venda/preco/adquirida_em/historico.
    // Continua sem validar o valor do pombcoins do lado do servidor —
    // mesma limitação do $POMB já registrada no ANTI-CHEAT-E-REGRAS.md.
    match /galeria/{id} {
      allow read: if logado();

      allow create: if logado() &&
        request.resource.data.a_venda == false &&
        request.resource.data.preco == 0;

      allow update: if logado() && (
        (resource.data.dono_uid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['a_venda', 'preco', 'colocada_venda_em'])) ||
        (resource.data.a_venda == true &&
          request.resource.data.dono_uid == request.auth.uid &&
          request.resource.data.a_venda == false)
      );

      allow delete: if false;
    }

    // Leilão semanal (arte-semanal.js): qualquer membro pode criar o
    // leilão da semana se não houver um ativo, e o timer de qualquer
    // membro pode encerrá-lo/registrar lances (mesma ressalva de
    // confiança client-side do $POMB citada acima).
    match /leiloes/{id} {
      allow read: if logado();
      allow create: if logado() && request.resource.data.status == 'ativo';
      allow update: if logado();
      allow delete: if false;

      match /lances/{lanceId} {
        allow read: if logado();
        allow create: if logado() && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /pagamentos/{id} {
      allow read: if logado() && resource.data.uid == request.auth.uid;
      allow write: if false; // REVISAR — nenhum arquivo enviado escreve aqui ainda
    }

    // Criado em galeria.html (comprarArte) dentro da mesma transação que
    // transfere a obra.
    match /transacoes/{id} {
      allow read: if logado() &&
        (resource.data.comprador == request.auth.uid || resource.data.vendedor == request.auth.uid);
      allow create: if logado() && request.resource.data.comprador == request.auth.uid;
      allow update, delete: if false;
    }

    // Qualquer coisa não listada acima: fechada por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
